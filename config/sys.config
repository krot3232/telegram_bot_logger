[
{kernel, [
  {logger_level, all},
  {logger, [
	{handler, default, logger_std_h,
                        #{
                            level => info,
                            filters => [
                                  {skip_progress_info, {fun logger_filters:progress/2, stop}}
                              ]
                        }},               
	{handler, telegram_handler_1, logger_telegram_h,
    #{
    level => info,
    config => #{
      fun_error_send=>fun logger:log/3,
      telegram_send_param=>#{
        chat_id=><<"@mychat_test_bot">>,
        parse_mode=><<"HTML">>
      },

      telegram_pool_options=>#{
            token=><<"1111111111:qwertyuiiotoken1234567890876654322">>
      }
    },
     filters => [
      {level, {fun logger_filters:level/2, {stop, neq, info}}},
      {skip_progress_info, {fun logger_filters:progress/2, stop}},
      {ignore_telegram_error_log, {fun logger_filters:domain/2, {stop, sub, [telegram_send_error]}}}
     ]
     ,formatter =>
            {logger_formatter,#{ 
              single_line => false,
              legacy_header => false,
              chars_limit => 4096,
              max_size => 4096,
              depth => unlimited,
              time_offset => "Z",
              time_designator => $\s,
              template => ["<i>",time,"</i>:",msg]
            }
          }
          %%
  }
  },
  {handler, handler_telegram_send_error, logger_std_h,
    #{
		    level => debug,
        config => #{
            file =>"/var/log/telegram_bot_api/telegram_send_error.log"
        },
		    filters => [
            {level, {fun logger_filters:level/2, {stop, neq, info}}},
            {skip_progress_info, {fun logger_filters:progress/2, stop}},
            {ignore_telegram_error_log, {fun logger_filters:domain/2, {stop, not_equal, [telegram_send_error]}}}
            ],
		    formatter => {
        logger_formatter, #{
            single_line => true,time_offset => "Z",time_designator => $\s,
            template => [time,":",telegram_handler_id,":",telegram_error_msg," send:",msg,"\n"]}}
    }
  }
  ]}

 ]}
].